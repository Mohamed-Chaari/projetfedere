# ──────────────────────────────────────────────────────────────
#  Météo Tunisie — Environment Configuration
#  Cloud-Native: Aiven Kafka (SSL) + Supabase PostgreSQL
# ──────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════
#  AIVEN KAFKA (SSL — required)
# ══════════════════════════════════════════════════════════════
KAFKA_BOOTSTRAP=kafka-projetfedere-projetfedere.l.aivencloud.com:21849
KAFKA_SECURITY_PROTOCOL=SSL

# SSL certificate paths (download from Aiven Console → Service → Overview)
KAFKA_CA_FILE=ca.pem
KAFKA_CERT_FILE=service.cert
KAFKA_KEY_FILE=service.key

# ══════════════════════════════════════════════════════════════
#  SUPABASE POSTGRESQL (required)
# ══════════════════════════════════════════════════════════════
DB_HOST=your_supabase_pooler_host_here
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_supabase_password_here

# ══════════════════════════════════════════════════════════════
#  WEATHER APIs
# ══════════════════════════════════════════════════════════════

# Open-Meteo (free, no key needed)
TIMEZONE=Africa/Tunis
START_DATE=2020-01-01
END_DATE=2024-12-31

# OpenWeatherMap (backup source)
OWM_API_KEY=your_openweathermap_api_key_here
