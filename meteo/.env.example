# ──────────────────────────────────────────────────────────────
#  Météo Tunisie — Environment Configuration (TEMPLATE)
#  Projet TD5 — ISIMS Sfax
# ──────────────────────────────────────────────────────────────

# Open-Meteo (free, no key needed)
TIMEZONE=Africa/Tunis
START_DATE=YYYY-MM-DD
END_DATE=YYYY-MM-DD

# Tunisia — cities in format name:lat:lon (comma-separated)
# Full registry is in src/utils/cities.py
CITIES=CityName:lat:lon,CityName:lat:lon

# OpenWeatherMap (backup)
OWM_API_KEY=your_free_api_key_here

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Kafka
KAFKA_BOOTSTRAP=kafka-projetfedere-projetfedere.l.aivencloud.com:21849
KAFKA_TOPIC=your-topic
KAFKA_DLQ=your-topic-dlq
# Optional overrides for SSL cert paths (auto-enabled when ca.pem exists)
KAFKA_SSL_CA_FILE=ca.pem
KAFKA_SSL_CERT_FILE=service.cert
KAFKA_SSL_KEY_FILE=service.key
